@startuml
title High-Level Architecture

actor "User" as user
node "API Gateway" as gate
node "Auth Service" as auth
node "Metadata Service" as metadata
database "PostgreSQL (shards)" as db
database "Redis (cache)" as redis
storage "MinIO" as s3

user --> gate
user --> s3
gate --> auth : JWT validation
gate --> metadata : download/upload
metadata --> db : CRUD
metadata --> redis : cache
metadata -> s3
@enduml