        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 4,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "sum by (service) (jvm_memory_used_bytes{area=\"heap\"})",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
